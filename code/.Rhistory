R[j,1:N[j]] <- dat$win[dat$block_id==c_j]
}
# check NA
C[is.na(C)] <- -99
R[is.na(R)] <- -99
d_stan <- list(J=J, N=N, maxN=maxN, C=C, R=R)
str(d_stan)
return(d_stan)
}
d_stan <- prep_stan_data(d_s1)
